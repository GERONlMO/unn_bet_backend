# Скопируйте в .env в корне репозитория: cp .env.example .env
# Файл .env в git не попадает. Один и тот же JWT_SECRET нужен auth-service и gateway-service.

# Base64-ключ для HS256 (минимум 256 бит). Сгенерировать: openssl rand -base64 32
JWT_SECRET=replace-me-with-openssl-rand-base64-32

# Срок жизни access-токена (мс), по умолчанию 86400000 = 1 день
# JWT_EXPIRATION=86400000

# Токен для /internal/* между микросервисами
INTERNAL_SERVICE_TOKEN=dev-internal-token
